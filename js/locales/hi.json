    "9_1": "\u0905\u092a\u0928\u0940 \u0905\u0902\u0924\u0930\u094d\u0926\u0943\u0937\u094d\u091f\u093f \u092a\u0930 \u092d\u0930\u094b\u0938\u093e \u0915\u0930\u0928\u093e",
