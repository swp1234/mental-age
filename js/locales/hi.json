    "child_description": "\u0906\u092a\u0915\u093e \u092e\u0938\u094d\u0924\u093f\u0937\u094d\u0915 \u092f\u0941\u0935\u093e\u0935\u0938\u094d\u0925\u093e \u0915\u0947 \u0906\u0936\u094d\u091a\u0930\u094d\u092f \u0914\u0930 \u0938\u094d\u0935\u0924:\u0938\u094d\u092b\u0942\u0930\u094d\u0924\u0924\u093e \u0938\u0947 \u0915\u093e\u092e \u0915\u0930\u0924\u093e \u0939\u0948\u0964 \u0906\u092a \u0924\u093e\u091c\u093c\u0940 \u0928\u091c\u093c\u0930 \u0914\u0930 \u0930\u091a\u0928\u093e\u0924\u094d\u092e\u0915 \u0938\u092e\u093e\u0927\u093e\u0928\u094b\u0902 \u0938\u0947 \u0938\u092e\u0938\u094d\u092f\u093e\u0913\u0902 \u0915\u093e \u0938\u093e\u092e\u0928\u093e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964 \u0915\u0941\u091b \u0915\u0949\u0917\u094d\u0928\u093f\u091f\u093f\u0935 \u0915\u094d\u0937\u0947\u0924\u094d\u0930 \u0905\u092d\u0940 \u0935\u093f\u0915\u0938\u093f\u0924 \u0939\u094b \u0930\u0939\u0947 \u0939\u0948\u0902, \u0932\u0947\u0915\u093f\u0928 \u0906\u092a\u0915\u0940 \u0915\u0932\u094d\u092a\u0928\u093e\u0936\u0940\u0932 \u0938\u094b\u091a \u090f\u0915 \u0936\u0915\u094d\u0924\u093f\u0936\u093e\u0932\u0940 \u0909\u092a\u0939\u093e\u0930 \u0939\u0948\u0964",
    "teenager": "\u0915\u093f\u0936\u094b\u0930 \u092d\u093e\u0935\u0928\u093e",
