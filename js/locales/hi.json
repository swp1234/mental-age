    "8_1": "\u0938\u0940\u0927\u0947 \u0921\u093e\u0902\u0938 \u092b\u094d\u0932\u094b\u0930 \u092a\u0930 \u091c\u093e\u0928\u093e",
    "8_2": "\u091c\u093f\u0924\u0928\u0947 \u0932\u094b\u0917\u094b\u0902 \u0938\u0947 \u0939\u094b \u0938\u0915\u0947 \u092c\u093e\u0924 \u0915\u0930\u0928\u093e",
    "8_3": "\u0915\u0941\u091b \u0932\u094b\u0917\u094b\u0902 \u0915\u0947 \u0938\u093e\u0925 \u0917\u0939\u0930\u0940 \u092c\u093e\u0924\u091a\u0940\u0924 \u0915\u0930\u0928\u093e",
