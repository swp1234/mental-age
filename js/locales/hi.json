    "balancedThinker_description": "\u0906\u092a\u0915\u0947 \u092e\u0928 \u0928\u0947 \u0905\u092a\u0928\u093e \u0938\u0902\u0924\u0941\u0932\u0928 \u092a\u093e \u0932\u093f\u092f\u093e \u0939\u0948\u0964 \u0906\u092a \u0924\u0930\u094d\u0915 \u0915\u094b \u092d\u093e\u0935\u0928\u093e \u0915\u0947 \u0938\u093e\u0925, \u092e\u0939\u0924\u094d\u0935\u093e\u0915\u093e\u0902\u0915\u094d\u0937\u093e \u0915\u094b \u0938\u0902\u0924\u094b\u0937 \u0915\u0947 \u0938\u093e\u0925, \u0914\u0930 \u0915\u094d\u0930\u093f\u092f\u093e \u0915\u094b \u091a\u093f\u0902\u0924\u0928 \u0915\u0947 \u0938\u093e\u0925 \u0938\u0902\u0924\u0941\u0932\u093f\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964 \u0906\u092a \u091c\u0940\u0935\u0928 \u0915\u0947 \u0906\u0928\u0902\u0926 \u0915\u093e \u092e\u091c\u093c\u093e \u0932\u0947\u0924\u0947 \u0939\u0941\u090f \u0938\u094b\u091a-\u0938\u092e\u091d\u0915\u0930 \u0928\u093f\u0930\u094d\u0923\u092f \u0932\u0947\u0924\u0947 \u0939\u0948\u0902\u0964",
    "balancedThinker_trait_1": "\u0909\u0924\u094d\u0915\u0943\u0937\u094d\u091f \u0928\u093f\u0930\u094d\u0923\u092f \u0915\u094d\u0937\u092e\u0924\u093e \u0914\u0930 \u0906\u0915\u0932\u0928",
    "balancedThinker_trait_2": "\u092d\u093e\u0935\u0928\u093e\u0924\u094d\u092e\u0915 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0914\u0930 \u0938\u0939\u093e\u0928\u0941\u092d\u0942\u0924\u093f",
    "balancedThinker_trait_3": "\u0935\u094d\u092f\u093e\u0935\u0939\u093e\u0930\u093f\u0915 \u0914\u0930 \u0930\u091a\u0928\u093e\u0924\u094d\u092e\u0915 \u0938\u092e\u0938\u094d\u092f\u093e \u0938\u092e\u093e\u0927\u093e\u0928\u0915\u0930\u094d\u0924\u093e",
    "balancedThinker_tip_1": "\u0915\u092d\u0940-\u0915\u092d\u0940 \u0905\u092a\u0928\u0947 \u0906\u0930\u093e\u092e \u0915\u094d\u0937\u0947\u0924\u094d\u0930 \u0938\u0947 \u092c\u093e\u0939\u0930 \u0928\u093f\u0915\u0932\u0928\u093e \u092f\u093e\u0926 \u0930\u0916\u0947\u0902",
    "balancedThinker_tip_2": "\u0906\u092a\u0915\u0940 \u0938\u094d\u0925\u093f\u0930\u0924\u093e \u090f\u0915 \u0935\u0930\u0926\u093e\u0928 \u0939\u0948 - \u091c\u093f\u0928\u094d\u0939\u0947\u0902 \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0928 \u0915\u0940 \u091c\u093c\u0930\u0942\u0930\u0924 \u0939\u0948 \u0909\u0928\u0915\u0947 \u0938\u093e\u0925 \u092c\u093e\u0901\u091f\u0947\u0902",
    "balancedThinker_famous": "\u092c\u0930\u093e\u0915 \u0913\u092c\u093e\u092e\u093e, \u0913\u092a\u0930\u093e \u0935\u093f\u0928\u092b\u094d\u0930\u0940, \u0932\u093f\u092f\u094b\u0928\u093e\u0930\u094d\u0926\u094b \u0926\u093e \u0935\u093f\u0902\u091a\u0940",

    "wiseMind": "\u092c\u0941\u0926\u094d\u0927\u093f\u092e\u093e\u0928 \u092e\u0928",
    "wiseMind_tagline": "\u0905\u0928\u0941\u092d\u0935 \u0914\u0930 \u0905\u0902\u0924\u0930\u094d\u0926\u0943\u0937\u094d\u091f\u093f \u0915\u093e \u0938\u0902\u0917\u092e!",
    "wiseMind_description": "\u0906\u092a\u0915\u0940 \u092e\u093e\u0928\u0938\u093f\u0915 \u0909\u092e\u094d\u0930 \u0917\u0939\u0930\u0947 \u0905\u0928\u0941\u092d\u0935 \u0914\u0930 \u0905\u0930\u094d\u091c\u093f\u0924 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0915\u094b \u0926\u0930\u094d\u0936\u093e\u0924\u0940 \u0939\u0948\u0964 \u0906\u092a \u0935\u094b \u092a\u0948\u091f\u0930\u094d\u0928 \u0926\u0947\u0916\u0924\u0947 \u0939\u0948\u0902 \u091c\u094b \u0926\u0942\u0938\u0930\u094b\u0902 \u0915\u094b \u0928\u0939\u0940\u0902 \u0926\u093f\u0916\u0924\u0947, \u092e\u093e\u0928\u0935 \u0938\u094d\u0935\u092d\u093e\u0935 \u0915\u094b \u0938\u0939\u091c \u0930\u0942\u092a \u0938\u0947 \u0938\u092e\u091d\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0936\u093e\u0902\u0924 \u0906\u0924\u094d\u092e\u0935\u093f\u0936\u094d\u0935\u093e\u0938 \u0915\u0947 \u0938\u093e\u0925 \u091c\u0940\u0935\u0928 \u091c\u0940\u0924\u0947 \u0939\u0948\u0902\u0964",
    "wiseMind_trait_1": "\u092e\u093e\u0928\u0935 \u0938\u094d\u0935\u092d\u093e\u0935 \u0915\u0940 \u0917\u0939\u0930\u0940 \u0938\u092e\u091d",
    "wiseMind_trait_2": "\u0927\u0948\u0930\u094d\u092f\u0935\u093e\u0928 \u0914\u0930 \u0935\u093f\u091a\u093e\u0930\u0936\u0940\u0932 \u0928\u093f\u0930\u094d\u0923\u092f\u0915\u0930\u094d\u0924\u093e",
    "wiseMind_trait_3": "\u0926\u0942\u0938\u0930\u094b\u0902 \u0915\u0947 \u0932\u093f\u090f \u0938\u094d\u0935\u093e\u092d\u093e\u0935\u093f\u0915 \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0915 \u0914\u0930 \u0938\u0932\u093e\u0939\u0915\u093e\u0930",
    "wiseMind_tip_1": "\u0928\u090f \u0935\u093f\u091a\u093e\u0930\u094b\u0902 \u0914\u0930 \u0924\u0915\u0928\u0940\u0915\u094b\u0902 \u0915\u0947 \u092a\u094d\u0930\u0924\u093f \u091c\u093f\u091c\u094d\u091e\u093e\u0938\u0941 \u092c\u0928\u0947 \u0930\u0939\u0947\u0902",
    "wiseMind_tip_2": "\u0906\u092a\u0915\u0940 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0905\u092e\u0942\u0932\u094d\u092f \u0939\u0948 - \u0936\u093f\u0915\u094d\u0937\u0923 \u092f\u093e \u0932\u0947\u0916\u0928 \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0907\u0938\u0947 \u092c\u093e\u0901\u091f\u0947\u0902",
    "wiseMind_famous": "\u092e\u0949\u0930\u094d\u0917\u0928 \u092b\u094d\u0930\u0940\u092e\u0948\u0928, \u0926\u0932\u093e\u0908 \u0932\u093e\u092e\u093e, \u092e\u0947\u0930\u093f\u0932 \u0938\u094d\u091f\u094d\u0930\u0940\u092a",

    "oldSoul": "\u092a\u0941\u0930\u093e\u0928\u0940 \u0906\u0924\u094d\u092e\u093e",
    "oldSoul_tagline": "\u0906\u0927\u0941\u0928\u093f\u0915 \u0926\u0941\u0928\u093f\u092f\u093e \u092e\u0947\u0902 \u090f\u0915 \u0936\u093e\u0936\u094d\u0935\u0924 \u0906\u0924\u094d\u092e\u093e!",
    "oldSoul_description": "\u0906\u092a \u092f\u0941\u0917\u094b\u0902 \u0915\u0940 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0932\u0947\u0915\u0930 \u091a\u0932\u0924\u0947 \u0939\u0948\u0902\u0964 \u0906\u092a\u0915\u093e \u0928\u091c\u093c\u0930\u093f\u092f\u093e \u0930\u0941\u091d\u093e\u0928\u094b\u0902 \u0914\u0930 \u092b\u0948\u0936\u0928 \u0938\u0947 \u092a\u0930\u0947 \u0939\u0948, \u091c\u094b \u0938\u091a\u092e\u0941\u091a \u092e\u093e\u092f\u0928\u0947 \u0930\u0916\u0924\u093e \u0939\u0948 \u0909\u0938 \u092a\u0930 \u0915\u0947\u0902\u0926\u094d\u0930\u093f\u0924 \u0939\u0948\u0964 \u0906\u092a \u0935\u093f\u0938\u094d\u0924\u093e\u0930 \u0938\u0947 \u091c\u094d\u092f\u093e\u0926\u093e \u0917\u0939\u0930\u093e\u0908, \u092e\u093e\u0924\u094d\u0930\u093e \u0938\u0947 \u091c\u094d\u092f\u093e\u0926\u093e \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e \u0915\u094b \u092e\u0939\u0924\u094d\u0935 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902\u0964",
    "oldSoul_trait_1": "\u0935\u093f\u091a\u093e\u0930 \u0914\u0930 \u091a\u093f\u0902\u0924\u0928 \u0915\u0940 \u0917\u0939\u0930\u0940 \u0917\u0939\u0930\u093e\u0908",
    "oldSoul_trait_2": "\u092a\u0930\u0902\u092a\u0930\u093e\u0913\u0902 \u0914\u0930 \u0936\u093e\u0936\u094d\u0935\u0924 \u0938\u093f\u0926\u094d\u0927\u093e\u0902\u0924\u094b\u0902 \u0915\u093e \u0938\u092e\u094d\u092e\u093e\u0928",
    "oldSoul_trait_3": "\u0936\u093e\u0902\u0924 \u0909\u092a\u0938\u094d\u0925\u093f\u0924\u093f \u091c\u094b \u0926\u0942\u0938\u0930\u094b\u0902 \u0915\u094b \u0938\u0939\u091c \u092c\u0928\u093e\u0924\u0940 \u0939\u0948",
    "oldSoul_tip_1": "\u0915\u0941\u091b \u0906\u0927\u0941\u0928\u093f\u0915 \u0928\u0935\u093e\u091a\u093e\u0930\u094b\u0902 \u0915\u094b \u0905\u092a\u0928\u093e\u090f\u0902 - \u092f\u0947 \u0906\u092a\u0915\u0940 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0915\u094b \u0914\u0930 \u0938\u092e\u0943\u0926\u094d\u0927 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902",
    "oldSoul_tip_2": "\u0906\u092a\u0915\u0940 \u0917\u0939\u0930\u093e\u0908 \u0926\u0941\u0930\u094d\u0932\u092d \u0939\u0948 - \u0909\u0928 \u0932\u094b\u0917\u094b\u0902 \u0915\u094b \u0916\u094b\u091c\u0947\u0902 \u091c\u094b \u0938\u093e\u0930\u094d\u0925\u0915 \u091c\u0941\u0921\u093c\u093e\u0935 \u0915\u0940 \u0915\u0926\u0930 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "oldSoul_famous": "\u0917\u0948\u0902\u0921\u0949\u0932\u094d\u092b, \u092f\u094b\u0926\u093e, \u0915\u0928\u094d\u092b\u094d\u092f\u0942\u0936\u093f\u092f\u0938",

    "ancientSage": "\u092a\u094d\u0930\u093e\u091a\u0940\u0928 \u0938\u0902\u0924",
    "ancientSage_tagline": "\u092a\u094d\u0930\u092c\u0941\u0926\u094d\u0927 \u092e\u0928, \u0936\u093e\u0936\u094d\u0935\u0924 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e!",
    "ancientSage_description": "\u0906\u092a\u0915\u0940 \u092e\u093e\u0928\u0938\u093f\u0915 \u0909\u092e\u094d\u0930 \u092a\u093e\u0930\u0902\u092a\u0930\u093f\u0915 \u092e\u093e\u092a\u0926\u0902\u0921\u094b\u0902 \u0938\u0947 \u092a\u0930\u0947 \u0939\u0948\u0964 \u0906\u092a\u0915\u0947 \u092a\u093e\u0938 \u0938\u092e\u091d \u0915\u0940 \u0926\u0941\u0930\u094d\u0932\u092d \u0917\u0939\u0930\u093e\u0908 \u0914\u0930 \u0926\u093e\u0930\u094d\u0936\u0928\u093f\u0915 \u0926\u0943\u0937\u094d\u091f\u093f\u0915\u094b\u0923 \u0939\u0948\u0964 \u0906\u092a \u0926\u0941\u0928\u093f\u092f\u093e \u0915\u094b \u0936\u093e\u0936\u094d\u0935\u0924 \u0938\u0924\u094d\u092f\u094b\u0902 \u0915\u0947 \u091a\u0936\u094d\u092e\u0947 \u0938\u0947 \u0926\u0947\u0916\u0924\u0947 \u0939\u0948\u0902\u0964",
    "ancientSage_trait_1": "\u0926\u093e\u0930\u094d\u0936\u0928\u093f\u0915 \u0914\u0930 \u091a\u093f\u0902\u0924\u0928\u0936\u0940\u0932 \u0938\u094d\u0935\u092d\u093e\u0935",
    "ancientSage_trait_2": "\u092c\u093e\u0939\u0930\u0940 \u0905\u0936\u093e\u0902\u0924\u093f \u0915\u0947 \u092c\u093e\u0935\u091c\u0942\u0926 \u0906\u0902\u0924\u0930\u093f\u0915 \u0936\u093e\u0902\u0924\u093f",
    "ancientSage_trait_3": "\u0939\u0930 \u091a\u0940\u091c\u093c \u092e\u0947\u0902 \u092c\u0921\u093c\u0940 \u0924\u0938\u094d\u0935\u0940\u0930 \u0926\u0947\u0916\u0928\u0947 \u0915\u0940 \u0915\u094d\u0937\u092e\u0924\u093e",
    "ancientSage_tip_1": "\u0917\u0939\u0928 \u091a\u093f\u0902\u0924\u0928 \u0915\u0947 \u0938\u093e\u0925-\u0938\u093e\u0925 \u091c\u0940\u0935\u0928 \u0915\u0947 \u0938\u093e\u0926\u0947 \u0906\u0928\u0902\u0926\u094b\u0902 \u0915\u093e \u092d\u0940 \u092e\u091c\u093c\u093e \u0932\u0947\u0928\u093e \u092f\u093e\u0926 \u0930\u0916\u0947\u0902",
    "ancientSage_tip_2": "\u0905\u092a\u0928\u0940 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0909\u0926\u093e\u0930\u0924\u093e \u0938\u0947 \u092c\u093e\u0901\u091f\u0947\u0902 - \u0926\u0941\u0928\u093f\u092f\u093e \u0915\u094b \u0907\u0938\u0915\u0940 \u092a\u0939\u0932\u0947 \u0938\u0947 \u0915\u0939\u0940\u0902 \u091c\u094d\u092f\u093e\u0926\u093e \u091c\u093c\u0930\u0942\u0930\u0924 \u0939\u0948",
    "ancientSage_famous": "\u092c\u0941\u0926\u094d\u0927, \u0938\u0941\u0915\u0930\u093e\u0924, \u0905\u0932\u094d\u092c\u0930\u094d\u091f \u0906\u0907\u0902\u0938\u094d\u091f\u0940\u0928"
  },
