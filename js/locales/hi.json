  },
  "age": {
    "youngSoul": "\u092f\u0941\u0935\u093e \u0906\u0924\u094d\u092e\u093e",
    "youngSoul_tagline": "\u0926\u093f\u0932 \u0938\u0947 \u0939\u092e\u0947\u0936\u093e \u091c\u0935\u093e\u0928!",
    "youngSoul_description": "\u0906\u092a\u0915\u093e \u092e\u0928 \u092f\u0941\u0935\u093e \u090a\u0930\u094d\u091c\u093e \u0938\u0947 \u0917\u0942\u0902\u091c\u0924\u093e \u0939\u0948! \u0906\u092a \u091c\u093f\u0902\u0926\u0917\u0940 \u0915\u094b \u091c\u093f\u091c\u094d\u091e\u093e\u0938\u093e, \u0938\u094d\u0935\u0924:\u0938\u094d\u092b\u0942\u0930\u094d\u0924\u0924\u093e \u0914\u0930 \u091b\u0942\u0924 \u0935\u093e\u0932\u0947 \u0909\u0924\u094d\u0938\u093e\u0939 \u0915\u0947 \u0938\u093e\u0925 \u091c\u0940\u0924\u0947 \u0939\u0948\u0902\u0964 \u0906\u092a \u091c\u094b\u0916\u093f\u092e \u0932\u0947\u0928\u0947 \u0938\u0947 \u0928\u0939\u0940\u0902 \u0921\u0930\u0924\u0947 \u0914\u0930 \u0906\u092a\u0915\u0940 \u0930\u091a\u0928\u093e\u0924\u094d\u092e\u0915\u0924\u093e \u0905\u0938\u0940\u092e\u093f\u0924 \u0939\u0948\u0964",
    "youngSoul_trait_1": "\u0905\u0938\u0940\u092e\u093f\u0924 \u0930\u091a\u0928\u093e\u0924\u094d\u092e\u0915\u0924\u093e \u0914\u0930 \u0915\u0932\u094d\u092a\u0928\u093e \u0936\u0915\u094d\u0924\u093f",
    "youngSoul_trait_2": "\u0938\u094d\u0935\u0924:\u0938\u094d\u092b\u0942\u0930\u094d\u0924 \u0914\u0930 \u0938\u093e\u0939\u0938\u0940 \u092d\u093e\u0935\u0928\u093e",
    "youngSoul_trait_3": "\u0928\u0908 \u091a\u0940\u091c\u093c\u094b\u0902 \u0915\u094b \u091c\u0932\u094d\u0926\u0940 \u0905\u092a\u0928\u093e\u0928\u0947 \u0914\u0930 \u0906\u091c\u093c\u092e\u093e\u0928\u0947 \u0915\u0940 \u0915\u094d\u0937\u092e\u0924\u093e",
    "youngSoul_tip_1": "\u0905\u092a\u0928\u0940 \u090a\u0930\u094d\u091c\u093e \u0915\u094b \u0926\u0940\u0930\u094d\u0918\u0915\u093e\u0932\u093f\u0915 \u0932\u0915\u094d\u0937\u094d\u092f\u094b\u0902 \u092e\u0947\u0902 \u0932\u0917\u093e\u090f\u0902 - \u092a\u0930\u093f\u0923\u093e\u092e \u0905\u0926\u094d\u092d\u0941\u0924 \u0939\u094b\u0902\u0917\u0947",
    "youngSoul_tip_2": "\u0927\u0948\u0930\u094d\u092f \u0930\u0916\u0947\u0902 - \u091c\u093f\u0902\u0926\u0917\u0940 \u0915\u0940 \u0938\u092c\u0938\u0947 \u0905\u091a\u094d\u091b\u0940 \u091a\u0940\u091c\u093c\u094b\u0902 \u092e\u0947\u0902 \u0938\u092e\u092f \u0932\u0917\u0924\u093e \u0939\u0948",
    "youngSoul_famous": "\u092a\u0940\u091f\u0930 \u092a\u0948\u0928, \u0917\u094b\u0915\u0942, \u0938\u094d\u092a\u0902\u091c\u092c\u0949\u092c",

    "freshMind": "\u0924\u0930\u094b\u0924\u093e\u091c\u093c\u093e \u092e\u0928",
    "freshMind_tagline": "\u092f\u0941\u0935\u093e\u092a\u0928 \u0914\u0930 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0915\u093e \u0938\u0939\u0940 \u092e\u093f\u0936\u094d\u0930\u0923!",
    "freshMind_description": "\u0906\u092a \u092f\u0941\u0935\u093e \u090a\u0930\u094d\u091c\u093e \u0915\u094b \u092c\u0922\u093c\u0924\u0940 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0915\u0947 \u0938\u093e\u0925 \u091c\u094b\u0921\u093c\u0924\u0947 \u0939\u0948\u0902\u0964 \u0906\u092a \u092e\u0939\u0924\u094d\u0935\u093e\u0915\u093e\u0902\u0915\u094d\u0937\u0940 \u0932\u0947\u0915\u093f\u0928 \u0935\u093f\u091a\u093e\u0930\u0936\u0940\u0932, \u0928\u093f\u0921\u0930 \u0932\u0947\u0915\u093f\u0928 \u0938\u0902\u0935\u0947\u0926\u0928\u0936\u0940\u0932 \u0939\u0948\u0902\u0964 \u092f\u0939 \u0935\u0939 \u0916\u093e\u0938 \u092c\u093f\u0902\u0926\u0941 \u0939\u0948 \u091c\u0939\u093e\u0901 \u0938\u092a\u0928\u0947 \u0926\u0943\u0922\u093c \u0938\u0902\u0915\u0932\u094d\u092a \u0938\u0947 \u092e\u093f\u0932\u0924\u0947 \u0939\u0948\u0902\u0964",
    "freshMind_trait_1": "\u0938\u094d\u092a\u0937\u094d\u091f \u0926\u093f\u0936\u093e \u0915\u0947 \u0938\u093e\u0925 \u092e\u0939\u0924\u094d\u0935\u093e\u0915\u093e\u0902\u0915\u094d\u0937\u0940",
    "freshMind_trait_2": "\u0916\u0941\u0932\u0947 \u0926\u093f\u092e\u093e\u0917 \u0914\u0930 \u0938\u0940\u0916\u0928\u0947 \u0915\u094b \u0924\u0948\u092f\u093e\u0930",
    "freshMind_trait_3": "\u092e\u091c\u093c\u0947 \u0914\u0930 \u091c\u093f\u092e\u094d\u092e\u0947\u0926\u093e\u0930\u0940 \u0915\u093e \u0905\u091a\u094d\u091b\u093e \u0938\u0902\u0924\u0941\u0932\u0928",
