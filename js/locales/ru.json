    "child_description": "\u0412\u0430\u0448 \u043c\u043e\u0437\u0433 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0441 \u0443\u0434\u0438\u0432\u043b\u0435\u043d\u0438\u0435\u043c \u0438 \u0441\u043f\u043e\u043d\u0442\u0430\u043d\u043d\u043e\u0441\u0442\u044c\u044e \u044e\u043d\u043e\u0441\u0442\u0438. \u0412\u044b \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442\u0435 \u043a \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430\u043c \u0441\u043e \u0441\u0432\u0435\u0436\u0438\u043c \u0432\u0437\u0433\u043b\u044f\u0434\u043e\u043c \u0438 \u043a\u0440\u0435\u0430\u0442\u0438\u0432\u043d\u044b\u043c\u0438 \u0440\u0435\u0448\u0435\u043d\u0438\u044f\u043c\u0438. \u041d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043a\u043e\u0433\u043d\u0438\u0442\u0438\u0432\u043d\u044b\u0435 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 \u0435\u0449\u0451 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u044e\u0442\u0441\u044f, \u043d\u043e \u0432\u0430\u0448\u0435 \u0431\u043e\u0433\u0430\u0442\u043e\u0435 \u0432\u043e\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u2014 \u043c\u043e\u0449\u043d\u044b\u0439 \u0434\u0430\u0440.",
    "teenager": "\u041f\u043e\u0434\u0440\u043e\u0441\u0442\u043a\u043e\u0432\u044b\u0439 \u0434\u0443\u0445",
    "teenager_tagline": "\u0411\u044b\u0441\u0442\u0440\u044b\u0435 \u0440\u0435\u0444\u043b\u0435\u043a\u0441\u044b, \u0441\u043c\u0435\u043b\u043e\u0435 \u043c\u044b\u0448\u043b\u0435\u043d\u0438\u0435!",
