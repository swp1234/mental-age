    "5_2": "\u0418\u0449\u0443 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435, \u0447\u0442\u043e\u0431\u044b \u043f\u043e\u043d\u044f\u0442\u044c",
    "5_3": "\u041d\u0430\u0445\u043e\u0436\u0443 \u0437\u0430\u0431\u0430\u0432\u043d\u044b\u043c, \u043d\u043e \u043d\u0435 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044e",
    "5_4": "\u041f\u0440\u0435\u0434\u043f\u043e\u0447\u0438\u0442\u0430\u044e \u0433\u0440\u0430\u043c\u043e\u0442\u043d\u0443\u044e \u0440\u0435\u0447\u044c \u0432 \u043b\u044e\u0431\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435",
    "6_1": "\u041f\u0430\u043d\u0438\u043a\u0430! \u041c\u043d\u0435 \u043d\u0443\u0436\u0435\u043d \u0442\u0435\u043b\u0435\u0444\u043e\u043d!",
    "6_2": "\u0411\u044b\u0441\u0442\u0440\u043e \u043d\u0430\u0439\u0442\u0438 \u0437\u0430\u0440\u044f\u0434\u043a\u0443",
    "6_3": "\u041f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0438\u0442\u044c\u0441\u044f \u043d\u0430 \u0447\u0442\u0435\u043d\u0438\u0435 \u043a\u043d\u0438\u0433\u0438",
    "6_4": "\u041d\u0438\u0447\u0435\u0433\u043e \u0441\u0442\u0440\u0430\u0448\u043d\u043e\u0433\u043e, \u044f \u0440\u0435\u0434\u043a\u043e \u0441\u043c\u043e\u0442\u0440\u044e \u0432 \u0442\u0435\u043b\u0435\u0444\u043e\u043d",
    "7_1": "\u0422\u0432\u043e\u0440\u0447\u0435\u0441\u043a\u0438\u0439 \u0445\u0430\u043e\u0441 \u2014 \u044f \u0437\u043d\u0430\u044e, \u0433\u0434\u0435 \u0432\u0441\u0451 \u043b\u0435\u0436\u0438\u0442",
    "7_2": "\u0411\u043e\u043b\u0435\u0435-\u043c\u0435\u043d\u0435\u0435 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u043e\u0432\u0430\u043d\u043e, \u043c\u043e\u0433\u043b\u043e \u0431\u044b \u0431\u044b\u0442\u044c \u043b\u0443\u0447\u0448\u0435",
    "7_3": "\u0423 \u0432\u0441\u0435\u0433\u043e \u0435\u0441\u0442\u044c \u0441\u0432\u043e\u0451 \u043c\u0435\u0441\u0442\u043e",
    "7_4": "\u0422\u0449\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u043e\u0432\u0430\u043d\u043e \u0438 \u043f\u043e\u0434\u043f\u0438\u0441\u0430\u043d\u043e",
    "8_1": "\u0421\u0440\u0430\u0437\u0443 \u043d\u0430 \u0442\u0430\u043d\u0446\u043f\u043e\u043b",
    "8_2": "\u041e\u0431\u0449\u0430\u044e\u0441\u044c \u0441 \u043a\u0430\u043a \u043c\u043e\u0436\u043d\u043e \u0431\u043e\u043b\u044c\u0448\u0438\u043c \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e\u043c \u043b\u044e\u0434\u0435\u0439",
    "8_3": "\u0412\u0435\u0434\u0443 \u0433\u043b\u0443\u0431\u043e\u043a\u0438\u0435 \u0440\u0430\u0437\u0433\u043e\u0432\u043e\u0440\u044b \u0441 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u043c\u0438 \u043b\u044e\u0434\u044c\u043c\u0438",
    "8_4": "\u041d\u0430\u0431\u043b\u044e\u0434\u0430\u044e \u0438 \u043d\u0430\u0441\u043b\u0430\u0436\u0434\u0430\u044e\u0441\u044c \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u043e\u0439",
    "9_1": "\u0414\u043e\u0432\u0435\u0440\u044f\u044e \u0441\u0432\u043e\u0435\u0439 \u0438\u043d\u0442\u0443\u0438\u0446\u0438\u0438",
    "9_2": "\u0421\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u044e \u0441\u043e\u0432\u0435\u0442\u0430 \u0443 \u0434\u0440\u0443\u0437\u0435\u0439 \u0438 \u0441\u0435\u043c\u044c\u0438",
    "9_3": "\u0421\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u044e \u043f\u043e\u0434\u0440\u043e\u0431\u043d\u044b\u0439 \u0441\u043f\u0438\u0441\u043e\u043a \u0437\u0430 \u0438 \u043f\u0440\u043e\u0442\u0438\u0432",
    "9_4": "\u0414\u0443\u043c\u0430\u044e \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0434\u043d\u0435\u0439",
    "10_1": "\u041d\u043e\u0432\u0435\u0439\u0448\u0438\u0435 \u0445\u0438\u0442\u044b \u0438 \u0442\u0440\u0435\u043d\u0434\u043e\u0432\u044b\u0435 \u043f\u0435\u0441\u043d\u0438",
    "10_2": "\u0421\u043c\u0435\u0441\u044c \u0432\u0441\u0435\u0433\u043e \u043f\u043e\u043d\u0435\u043c\u043d\u043e\u0433\u0443",
    "10_3": "\u041a\u043b\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043b\u044e\u0431\u0438\u043c\u044b\u0435 \u043f\u0435\u0441\u043d\u0438 \u0438\u0437 \u044e\u043d\u043e\u0441\u0442\u0438",
    "10_4": "\u0414\u0436\u0430\u0437, \u043a\u043b\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043b\u0438 \u044d\u043c\u0431\u0438\u0435\u043d\u0442-\u043c\u0443\u0437\u044b\u043a\u0430",
    "11_1": "\u0412 \u0432\u043e\u0441\u0442\u043e\u0440\u0433\u0435! \u0414\u0430\u0432\u0430\u0439\u0442\u0435!",
    "11_2": "\u041b\u044e\u0431\u043e\u043f\u044b\u0442\u043d\u043e, \u043d\u043e \u043d\u0435\u043c\u043d\u043e\u0433\u043e \u043d\u0430\u0441\u0442\u043e\u0440\u043e\u0436\u0435\u043d\u043d\u043e",
    "11_3": "\u041f\u043e\u0441\u0442\u0435\u043f\u0435\u043d\u043d\u043e \u0430\u0434\u0430\u043f\u0442\u0438\u0440\u0443\u044e\u0441\u044c \u0441\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0435\u043c",
    "11_4": "\u041f\u0440\u0435\u0434\u043f\u043e\u0447\u0438\u0442\u0430\u044e \u0441\u0442\u0430\u0431\u0438\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0438 \u0440\u0443\u0442\u0438\u043d\u0443",
    "12_1": "\u0412\u0435\u0441\u0435\u043b\u044c\u0435 \u0438 \u0441\u043f\u043e\u043d\u0442\u0430\u043d\u043d\u043e\u0441\u0442\u044c",
    "12_2": "\u041e\u0431\u0449\u0438\u0435 \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u044b \u0438 \u0443\u0432\u043b\u0435\u0447\u0435\u043d\u0438\u044f",
    "12_3": "\u0412\u0435\u0440\u043d\u043e\u0441\u0442\u044c \u0438 \u0434\u043e\u0432\u0435\u0440\u0438\u0435 \u043f\u0440\u0435\u0432\u044b\u0448\u0435 \u0432\u0441\u0435\u0433\u043e",
    "12_4": "\u0413\u043b\u0443\u0431\u043e\u043a\u043e\u0435 \u0432\u0437\u0430\u0438\u043c\u043e\u043f\u043e\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u0438 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c",
    "13_1": "\u0421\u0440\u0430\u0437\u0443 \u043f\u043e\u0433\u0440\u0443\u0436\u0430\u044e\u0441\u044c \u0438 \u044d\u043a\u0441\u043f\u0435\u0440\u0438\u043c\u0435\u043d\u0442\u0438\u0440\u0443\u044e",
    "13_2": "\u0421\u043c\u043e\u0442\u0440\u044e \u043e\u0431\u0443\u0447\u0430\u044e\u0449\u0438\u0435 \u0432\u0438\u0434\u0435\u043e",
    "13_3": "\u0421\u043d\u0430\u0447\u0430\u043b\u0430 \u0432\u043d\u0438\u043c\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u0447\u0438\u0442\u0430\u044e \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u044e",
    "13_4": "\u041d\u0430\u0445\u043e\u0436\u0443 \u043e\u043f\u044b\u0442\u043d\u043e\u0433\u043e \u043d\u0430\u0441\u0442\u0430\u0432\u043d\u0438\u043a\u0430",
    "14_1": "\u041e\u0431\u0441\u0443\u0436\u0434\u0430\u044e \u0441 \u0434\u0440\u0443\u0437\u044c\u044f\u043c\u0438",
    "14_2": "\u0417\u0430\u043d\u0438\u043c\u0430\u044e\u0441\u044c \u0441\u043f\u043e\u0440\u0442\u043e\u043c \u0438\u043b\u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c\u044e",
    "14_3": "\u041f\u0438\u0448\u0443 \u0434\u043d\u0435\u0432\u043d\u0438\u043a \u0438\u043b\u0438 \u0440\u0430\u0437\u043c\u044b\u0448\u043b\u044f\u044e",
    "14_4": "\u041c\u0435\u0434\u0438\u0442\u0438\u0440\u0443\u044e \u0438\u043b\u0438 \u0441\u0438\u0436\u0443 \u0432 \u0442\u0438\u0448\u0438\u043d\u0435",
    "15_1": "\u0423\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043d\u043e\u0432\u044b\u0439 \u043e\u043f\u044b\u0442",
    "15_2": "\u041f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u0435 \u0434\u043e\u0441\u0442\u0438\u0436\u0435\u043d\u0438\u044f \u0438 \u0446\u0435\u043b\u0438",
    "15_3": "\u0417\u043d\u0430\u0447\u0438\u043c\u044b\u0435 \u0441\u0432\u044f\u0437\u0438 \u0441 \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u043b\u044e\u0434\u044c\u043c\u0438",
    "15_4": "\u0412\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0439 \u043f\u043e\u043a\u043e\u0439 \u0438 \u0443\u043c\u0438\u0440\u043e\u0442\u0432\u043e\u0440\u0435\u043d\u0438\u0435"
  },
  "age": {
    "youngSoul": "\u041c\u043e\u043b\u043e\u0434\u0430\u044f \u0434\u0443\u0448\u0430",
    "youngSoul_tagline": "\u0412\u0435\u0447\u043d\u043e \u043c\u043e\u043b\u043e\u0434\u043e\u0439 \u0432 \u0434\u0443\u0448\u0435!",
    "youngSoul_description": "\u0412\u0430\u0448 \u0440\u0430\u0437\u0443\u043c \u043a\u0438\u043f\u0438\u0442 \u044e\u043d\u043e\u0439 \u044d\u043d\u0435\u0440\u0433\u0438\u0435\u0439! \u0412\u044b \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442\u0435 \u043a \u0436\u0438\u0437\u043d\u0438 \u0441 \u043b\u044e\u0431\u043e\u043f\u044b\u0442\u0441\u0442\u0432\u043e\u043c, \u0441\u043f\u043e\u043d\u0442\u0430\u043d\u043d\u043e\u0441\u0442\u044c\u044e \u0438 \u0437\u0430\u0440\u0430\u0437\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u043c \u044d\u043d\u0442\u0443\u0437\u0438\u0430\u0437\u043c\u043e\u043c. \u0412\u044b \u043d\u0435 \u0431\u043e\u0438\u0442\u0435\u0441\u044c \u0440\u0438\u0441\u043a\u043e\u0432\u0430\u0442\u044c, \u0430 \u0432\u0430\u0448\u0430 \u043a\u0440\u0435\u0430\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c \u043d\u0435 \u0437\u043d\u0430\u0435\u0442 \u0433\u0440\u0430\u043d\u0438\u0446.",
    "youngSoul_trait_1": "\u0411\u0435\u0437\u0433\u0440\u0430\u043d\u0438\u0447\u043d\u0430\u044f \u043a\u0440\u0435\u0430\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c \u0438 \u0432\u043e\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435",
    "youngSoul_trait_2": "\u0421\u043f\u043e\u043d\u0442\u0430\u043d\u043d\u044b\u0439 \u0438 \u0430\u0432\u0430\u043d\u0442\u044e\u0440\u043d\u044b\u0439 \u0434\u0443\u0445",
    "youngSoul_trait_3": "\u0411\u044b\u0441\u0442\u0440\u0430\u044f \u0430\u0434\u0430\u043f\u0442\u0430\u0446\u0438\u044f \u0438 \u0433\u043e\u0442\u043e\u0432\u043d\u043e\u0441\u0442\u044c \u043a \u043d\u043e\u0432\u043e\u043c\u0443",
    "youngSoul_tip_1": "\u041d\u0430\u043f\u0440\u0430\u0432\u044c\u0442\u0435 \u0441\u0432\u043e\u044e \u044d\u043d\u0435\u0440\u0433\u0438\u044e \u043d\u0430 \u0434\u043e\u043b\u0433\u043e\u0441\u0440\u043e\u0447\u043d\u044b\u0435 \u0446\u0435\u043b\u0438 \u0434\u043b\u044f \u043f\u043e\u0442\u0440\u044f\u0441\u0430\u044e\u0449\u0438\u0445 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u043e\u0432",
    "youngSoul_tip_2": "\u0422\u0440\u0435\u043d\u0438\u0440\u0443\u0439\u0442\u0435 \u0442\u0435\u0440\u043f\u0435\u043d\u0438\u0435 \u2014 \u043b\u0443\u0447\u0448\u0435\u0435 \u0432 \u0436\u0438\u0437\u043d\u0438 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0432\u0440\u0435\u043c\u0435\u043d\u0438",
    "youngSoul_famous": "\u041f\u0438\u0442\u0435\u0440 \u041f\u044d\u043d, \u0413\u043e\u043a\u0443, \u0413\u0443\u0431\u043a\u0430 \u0411\u043e\u0431",

    "freshMind": "\u0421\u0432\u0435\u0436\u0438\u0439 \u0440\u0430\u0437\u0443\u043c",
    "freshMind_tagline": "\u0418\u0434\u0435\u0430\u043b\u044c\u043d\u044b\u0439 \u0441\u043f\u043b\u0430\u0432 \u043c\u043e\u043b\u043e\u0434\u043e\u0441\u0442\u0438 \u0438 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u0438!",
    "freshMind_description": "\u0412\u044b \u0441\u043e\u0447\u0435\u0442\u0430\u0435\u0442\u0435 \u044e\u043d\u0443\u044e \u044d\u043d\u0435\u0440\u0433\u0438\u044e \u0441 \u0440\u0430\u0441\u0442\u0443\u0449\u0435\u0439 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c\u044e. \u0412\u044b \u0430\u043c\u0431\u0438\u0446\u0438\u043e\u0437\u043d\u044b, \u043d\u043e \u0432\u0434\u0443\u043c\u0447\u0438\u0432\u044b; \u0441\u043c\u0435\u043b\u044b, \u043d\u043e \u0432\u043d\u0438\u043c\u0430\u0442\u0435\u043b\u044c\u043d\u044b. \u042d\u0442\u043e \u0442\u0430 \u0441\u0430\u043c\u0430\u044f \u0442\u043e\u0447\u043a\u0430, \u0433\u0434\u0435 \u043c\u0435\u0447\u0442\u044b \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442\u0441\u044f \u0441 \u0440\u0435\u0448\u0438\u043c\u043e\u0441\u0442\u044c\u044e.",
    "freshMind_trait_1": "\u0410\u043c\u0431\u0438\u0446\u0438\u043e\u0437\u043d\u043e\u0441\u0442\u044c \u0441 \u0447\u0451\u0442\u043a\u0438\u043c \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435\u043c",
    "freshMind_trait_2": "\u041e\u0442\u043a\u0440\u044b\u0442\u043e\u0441\u0442\u044c \u0438 \u0433\u043e\u0442\u043e\u0432\u043d\u043e\u0441\u0442\u044c \u0443\u0447\u0438\u0442\u044c\u0441\u044f",
    "freshMind_trait_3": "\u0425\u043e\u0440\u043e\u0448\u0438\u0439 \u0431\u0430\u043b\u0430\u043d\u0441 \u043c\u0435\u0436\u0434\u0443 \u0432\u0435\u0441\u0435\u043b\u044c\u0435\u043c \u0438 \u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u044c\u044e",
    "freshMind_tip_1": "\u0411\u043e\u043b\u044c\u0448\u0435 \u0434\u043e\u0432\u0435\u0440\u044f\u0439\u0442\u0435 \u0438\u043d\u0442\u0443\u0438\u0446\u0438\u0438 \u2014 \u043e\u043d\u0430 \u043e\u0441\u0442\u0440\u0435\u0435, \u0447\u0435\u043c \u0432\u044b \u0434\u0443\u043c\u0430\u0435\u0442\u0435",
    "freshMind_tip_2": "\u041d\u0435 \u0442\u0435\u0440\u044f\u0439\u0442\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u043e \u0443\u0434\u0438\u0432\u043b\u0435\u043d\u0438\u044f, \u043a\u043e\u0433\u0434\u0430 \u043e\u0431\u044f\u0437\u0430\u043d\u043d\u043e\u0441\u0442\u0435\u0439 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0441\u044f \u0431\u043e\u043b\u044c\u0448\u0435",
    "freshMind_famous": "\u0418\u043b\u043e\u043d \u041c\u0430\u0441\u043a (\u043f\u043e \u0434\u0443\u0445\u0443), \u041c\u0430\u0440\u0438\u044f \u041a\u044e\u0440\u0438 (\u0440\u0430\u043d\u043d\u0438\u0435 \u0433\u043e\u0434\u044b), \u0421\u0442\u0438\u0432 \u0414\u0436\u043e\u0431\u0441 (\u044d\u043f\u043e\u0445\u0430 \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u044f Apple)",

    "balancedThinker": "\u0421\u0431\u0430\u043b\u0430\u043d\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u043c\u044b\u0441\u043b\u0438\u0442\u0435\u043b\u044c",
    "balancedThinker_tagline": "\u0417\u043e\u043b\u043e\u0442\u0430\u044f \u0441\u0435\u0440\u0435\u0434\u0438\u043d\u0430 \u0443\u043c\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u0437\u0440\u0435\u043b\u043e\u0441\u0442\u0438!",
    "balancedThinker_description": "\u0412\u0430\u0448 \u0440\u0430\u0437\u0443\u043c \u043d\u0430\u0448\u0451\u043b \u0440\u0430\u0432\u043d\u043e\u0432\u0435\u0441\u0438\u0435. \u0412\u044b \u0441\u043e\u0447\u0435\u0442\u0430\u0435\u0442\u0435 \u043b\u043e\u0433\u0438\u043a\u0443 \u0441 \u044d\u043c\u043e\u0446\u0438\u044f\u043c\u0438, \u0430\u043c\u0431\u0438\u0446\u0438\u0438 \u0441 \u0443\u0434\u043e\u0432\u043b\u0435\u0442\u0432\u043e\u0440\u0451\u043d\u043d\u043e\u0441\u0442\u044c\u044e, \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0441 \u0440\u0430\u0437\u043c\u044b\u0448\u043b\u0435\u043d\u0438\u0435\u043c. \u0412\u044b \u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0435\u0442\u0435 \u0432\u0437\u0432\u0435\u0448\u0435\u043d\u043d\u044b\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u044f, \u043d\u0430\u0441\u043b\u0430\u0436\u0434\u0430\u044f\u0441\u044c \u0436\u0438\u0437\u043d\u044c\u044e.",
    "balancedThinker_trait_1": "\u041e\u0442\u043b\u0438\u0447\u043d\u043e\u0435 \u0441\u0443\u0436\u0434\u0435\u043d\u0438\u0435 \u0438 \u043f\u0440\u0438\u043d\u044f\u0442\u0438\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u0439",
    "balancedThinker_trait_2": "\u042d\u043c\u043e\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u0439 \u0438\u043d\u0442\u0435\u043b\u043b\u0435\u043a\u0442 \u0438 \u044d\u043c\u043f\u0430\u0442\u0438\u044f",
    "balancedThinker_trait_3": "\u041f\u0440\u0430\u043a\u0442\u0438\u0447\u043d\u044b\u0439 \u0438 \u0432 \u0442\u043e \u0436\u0435 \u0432\u0440\u0435\u043c\u044f \u0442\u0432\u043e\u0440\u0447\u0435\u0441\u043a\u0438\u0439 \u0440\u0435\u0448\u0430\u0442\u0435\u043b\u044c \u043f\u0440\u043e\u0431\u043b\u0435\u043c",
    "balancedThinker_tip_1": "\u041d\u0435 \u0437\u0430\u0431\u044b\u0432\u0430\u0439\u0442\u0435 \u0438\u043d\u043e\u0433\u0434\u0430 \u0432\u044b\u0445\u043e\u0434\u0438\u0442\u044c \u0438\u0437 \u0437\u043e\u043d\u044b \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u0430",
    "balancedThinker_tip_2": "\u0412\u0430\u0448\u0430 \u0441\u0442\u0430\u0431\u0438\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u2014 \u044d\u0442\u043e \u0434\u0430\u0440, \u0434\u0435\u043b\u0438\u0442\u0435\u0441\u044c \u0438\u043c \u0441 \u0442\u0435\u043c\u0438, \u043a\u0442\u043e \u043d\u0443\u0436\u0434\u0430\u0435\u0442\u0441\u044f \u0432 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0438",
    "balancedThinker_famous": "\u0411\u0430\u0440\u0430\u043a \u041e\u0431\u0430\u043c\u0430, \u041e\u043f\u0440\u0430 \u0423\u0438\u043d\u0444\u0440\u0438, \u041b\u0435\u043e\u043d\u0430\u0440\u0434\u043e \u0434\u0430 \u0412\u0438\u043d\u0447\u0438",

    "wiseMind": "\u041c\u0443\u0434\u0440\u044b\u0439 \u0440\u0430\u0437\u0443\u043c",
    "wiseMind_tagline": "\u041e\u043f\u044b\u0442 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442 \u043f\u0440\u043e\u043d\u0438\u0446\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c!",
    "wiseMind_description": "\u0412\u0430\u0448 \u043c\u0435\u043d\u0442\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u043e\u0437\u0440\u0430\u0441\u0442 \u043e\u0442\u0440\u0430\u0436\u0430\u0435\u0442 \u0433\u043b\u0443\u0431\u043e\u043a\u0438\u0439 \u043e\u043f\u044b\u0442 \u0438 \u043e\u0431\u0440\u0435\u0442\u0451\u043d\u043d\u0443\u044e \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c. \u0412\u044b \u0432\u0438\u0434\u0438\u0442\u0435 \u0437\u0430\u043a\u043e\u043d\u043e\u043c\u0435\u0440\u043d\u043e\u0441\u0442\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0434\u0440\u0443\u0433\u0438\u0435 \u0443\u043f\u0443\u0441\u043a\u0430\u044e\u0442, \u0438\u043d\u0442\u0443\u0438\u0442\u0438\u0432\u043d\u043e \u043f\u043e\u043d\u0438\u043c\u0430\u0435\u0442\u0435 \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u0443\u044e \u043f\u0440\u0438\u0440\u043e\u0434\u0443 \u0438 \u0438\u0434\u0451\u0442\u0435 \u043f\u043e \u0436\u0438\u0437\u043d\u0438 \u0441\u043e \u0441\u043f\u043e\u043a\u043e\u0439\u043d\u043e\u0439 \u0443\u0432\u0435\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u044c\u044e.",
    "wiseMind_trait_1": "\u0413\u043b\u0443\u0431\u043e\u043a\u043e\u0435 \u043f\u043e\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u043e\u0439 \u043f\u0440\u0438\u0440\u043e\u0434\u044b",
    "wiseMind_trait_2": "\u0422\u0435\u0440\u043f\u0435\u043b\u0438\u0432\u044b\u0439 \u0438 \u0432\u0434\u0443\u043c\u0447\u0438\u0432\u044b\u0439 \u043f\u0440\u0438 \u043f\u0440\u0438\u043d\u044f\u0442\u0438\u0438 \u0440\u0435\u0448\u0435\u043d\u0438\u0439",
    "wiseMind_trait_3": "\u041f\u0440\u0438\u0440\u043e\u0436\u0434\u0451\u043d\u043d\u044b\u0439 \u043d\u0430\u0441\u0442\u0430\u0432\u043d\u0438\u043a \u0438 \u0441\u043e\u0432\u0435\u0442\u0447\u0438\u043a",
    "wiseMind_tip_1": "\u041e\u0441\u0442\u0430\u0432\u0430\u0439\u0442\u0435\u0441\u044c \u043b\u044e\u0431\u043e\u0437\u043d\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u043c\u0438 \u043a \u043d\u043e\u0432\u044b\u043c \u0438\u0434\u0435\u044f\u043c \u0438 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u044f\u043c",
    "wiseMind_tip_2": "\u0412\u0430\u0448\u0430 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c \u0431\u0435\u0441\u0446\u0435\u043d\u043d\u0430 \u2014 \u043f\u043e\u0434\u0443\u043c\u0430\u0439\u0442\u0435 \u043e \u0442\u043e\u043c, \u0447\u0442\u043e\u0431\u044b \u0434\u0435\u043b\u0438\u0442\u044c\u0441\u044f \u0435\u044e \u0447\u0435\u0440\u0435\u0437 \u043f\u0440\u0435\u043f\u043e\u0434\u0430\u0432\u0430\u043d\u0438\u0435 \u0438\u043b\u0438 \u043f\u0438\u0441\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u043e",
    "wiseMind_famous": "\u041c\u043e\u0440\u0433\u0430\u043d \u0424\u0440\u0438\u043c\u0435\u043d, \u0414\u0430\u043b\u0430\u0439-\u043b\u0430\u043c\u0430, \u041c\u0435\u0440\u0438\u043b \u0421\u0442\u0440\u0438\u043f",

    "oldSoul": "\u0421\u0442\u0430\u0440\u0430\u044f \u0434\u0443\u0448\u0430",
    "oldSoul_tagline": "\u0412\u0435\u0447\u043d\u044b\u0439 \u0434\u0443\u0445 \u0432 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u043c \u043c\u0438\u0440\u0435!",
    "oldSoul_description": "\u0412\u044b \u043d\u0435\u0441\u0451\u0442\u0435 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c \u0432\u0435\u043a\u043e\u0432. \u0412\u0430\u0448 \u0432\u0437\u0433\u043b\u044f\u0434 \u0432\u044b\u0445\u043e\u0434\u0438\u0442 \u0437\u0430 \u0440\u0430\u043c\u043a\u0438 \u0442\u0440\u0435\u043d\u0434\u043e\u0432 \u0438 \u043c\u043e\u0434\u044b, \u0441\u043e\u0441\u0440\u0435\u0434\u043e\u0442\u0430\u0447\u0438\u0432\u0430\u044f\u0441\u044c \u043d\u0430 \u0442\u043e\u043c, \u0447\u0442\u043e \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u0432\u0430\u0436\u043d\u043e. \u0412\u044b \u0446\u0435\u043d\u0438\u0442\u0435 \u0433\u043b\u0443\u0431\u0438\u043d\u0443 \u0431\u043e\u043b\u044c\u0448\u0435 \u0448\u0438\u0440\u043e\u0442\u044b, \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u043e \u0431\u043e\u043b\u044c\u0448\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0430.",
    "oldSoul_trait_1": "\u0413\u043b\u0443\u0431\u0438\u043d\u0430 \u043c\u044b\u0441\u043b\u0438 \u0438 \u0440\u0435\u0444\u043b\u0435\u043a\u0441\u0438\u0438",
    "oldSoul_trait_2": "\u0423\u0432\u0430\u0436\u0435\u043d\u0438\u0435 \u043a \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044f\u043c \u0438 \u0432\u0435\u0447\u043d\u044b\u043c \u043f\u0440\u0438\u043d\u0446\u0438\u043f\u0430\u043c",
    "oldSoul_trait_3": "\u0421\u043f\u043e\u043a\u043e\u0439\u043d\u043e\u0435 \u043f\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435, \u0443\u0441\u043f\u043e\u043a\u0430\u0438\u0432\u0430\u044e\u0449\u0435\u0435 \u043e\u043a\u0440\u0443\u0436\u0430\u044e\u0449\u0438\u0445",
    "oldSoul_tip_1": "\u041f\u0440\u0438\u043c\u0438\u0442\u0435 \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0435 \u0438\u043d\u043d\u043e\u0432\u0430\u0446\u0438\u0438 \u2014 \u043e\u043d\u0438 \u043c\u043e\u0433\u0443\u0442 \u043e\u0431\u043e\u0433\u0430\u0442\u0438\u0442\u044c \u0432\u0430\u0448\u0443 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c",
    "oldSoul_tip_2": "\u0412\u0430\u0448\u0430 \u0433\u043b\u0443\u0431\u0438\u043d\u0430 \u0440\u0435\u0434\u043a\u043e\u0441\u0442\u044c \u2014 \u043d\u0430\u0439\u0434\u0438\u0442\u0435 \u0442\u0435\u0445, \u043a\u0442\u043e \u0446\u0435\u043d\u0438\u0442 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0435 \u0441\u0432\u044f\u0437\u0438",
    "oldSoul_famous": "\u0413\u044d\u043d\u0434\u0430\u043b\u044c\u0444, \u0419\u043e\u0434\u0430, \u041a\u043e\u043d\u0444\u0443\u0446\u0438\u0439",

    "ancientSage": "\u0414\u0440\u0435\u0432\u043d\u0438\u0439 \u043c\u0443\u0434\u0440\u0435\u0446",
    "ancientSage_tagline": "\u041f\u0440\u043e\u0441\u0432\u0435\u0442\u043b\u0451\u043d\u043d\u044b\u0439 \u0440\u0430\u0437\u0443\u043c, \u0432\u0435\u0447\u043d\u0430\u044f \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c!",
    "ancientSage_description": "\u0412\u0430\u0448 \u043c\u0435\u043d\u0442\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u043e\u0437\u0440\u0430\u0441\u0442 \u0432\u044b\u0445\u043e\u0434\u0438\u0442 \u0437\u0430 \u043e\u0431\u044b\u0447\u043d\u044b\u0435 \u043c\u0435\u0440\u043a\u0438. \u0412\u044b \u043e\u0431\u043b\u0430\u0434\u0430\u0435\u0442\u0435 \u0440\u0435\u0434\u043a\u043e\u0439 \u0433\u043b\u0443\u0431\u0438\u043d\u043e\u0439 \u043f\u043e\u043d\u0438\u043c\u0430\u043d\u0438\u044f \u0438 \u0444\u0438\u043b\u043e\u0441\u043e\u0444\u0441\u043a\u0438\u043c \u0432\u0437\u0433\u043b\u044f\u0434\u043e\u043c \u043d\u0430 \u043c\u0438\u0440. \u0412\u044b \u0432\u0438\u0434\u0438\u0442\u0435 \u043c\u0438\u0440 \u0441\u043a\u0432\u043e\u0437\u044c \u043f\u0440\u0438\u0437\u043c\u0443 \u0432\u0435\u0447\u043d\u044b\u0445 \u0438\u0441\u0442\u0438\u043d.",
    "ancientSage_trait_1": "\u0424\u0438\u043b\u043e\u0441\u043e\u0444\u0441\u043a\u0430\u044f \u0438 \u0441\u043e\u0437\u0435\u0440\u0446\u0430\u0442\u0435\u043b\u044c\u043d\u0430\u044f \u043d\u0430\u0442\u0443\u0440\u0430",
    "ancientSage_trait_2": "\u0412\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0439 \u043f\u043e\u043a\u043e\u0439 \u043d\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e \u043e\u0442 \u0432\u043d\u0435\u0448\u043d\u0435\u0433\u043e \u0445\u0430\u043e\u0441\u0430",
    "ancientSage_trait_3": "\u0421\u043f\u043e\u0441\u043e\u0431\u043d\u043e\u0441\u0442\u044c \u0432\u0438\u0434\u0435\u0442\u044c \u043e\u0431\u0449\u0443\u044e \u043a\u0430\u0440\u0442\u0438\u043d\u0443 \u0432\u043e \u0432\u0441\u0451\u043c",
    "ancientSage_tip_1": "\u041d\u0435 \u0437\u0430\u0431\u044b\u0432\u0430\u0439\u0442\u0435 \u043d\u0430\u0441\u043b\u0430\u0436\u0434\u0430\u0442\u044c\u0441\u044f \u043f\u0440\u043e\u0441\u0442\u044b\u043c\u0438 \u0440\u0430\u0434\u043e\u0441\u0442\u044f\u043c\u0438 \u0436\u0438\u0437\u043d\u0438 \u043d\u0430\u0440\u044f\u0434\u0443 \u0441 \u0433\u043b\u0443\u0431\u043e\u043a\u0438\u043c\u0438 \u0440\u0430\u0437\u043c\u044b\u0448\u043b\u0435\u043d\u0438\u044f\u043c\u0438",
    "ancientSage_tip_2": "\u0414\u0435\u043b\u0438\u0442\u0435\u0441\u044c \u0441\u0432\u043e\u0435\u0439 \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c\u044e \u0449\u0435\u0434\u0440\u043e \u2014 \u043c\u0438\u0440 \u043d\u0443\u0436\u0434\u0430\u0435\u0442\u0441\u044f \u0432 \u043d\u0435\u0439 \u043a\u0430\u043a \u043d\u0438\u043a\u043e\u0433\u0434\u0430",
    "ancientSage_famous": "\u0411\u0443\u0434\u0434\u0430, \u0421\u043e\u043a\u0440\u0430\u0442, \u0410\u043b\u044c\u0431\u0435\u0440\u0442 \u042d\u0439\u043d\u0448\u0442\u0435\u0439\u043d"
  },
