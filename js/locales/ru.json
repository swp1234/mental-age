    "youngAdult": "\u041c\u043e\u043b\u043e\u0434\u043e\u0439 \u0432\u0437\u0440\u043e\u0441\u043b\u044b\u0439",
    "youngAdult_tagline": "\u041e\u0441\u0442\u0440\u044b\u0439 \u0443\u043c, \u0441\u0431\u0430\u043b\u0430\u043d\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0435 \u043c\u044b\u0448\u043b\u0435\u043d\u0438\u0435!",
    "youngAdult_description": "\u0412\u0430\u0448 \u043c\u043e\u0437\u0433 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043d\u0430 \u043f\u043e\u043b\u043d\u0443\u044e \u043c\u043e\u0449\u043d\u043e\u0441\u0442\u044c. \u0412\u044b \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442\u0435 \u0441\u0438\u043b\u044c\u043d\u044b\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0432 \u043f\u0430\u043c\u044f\u0442\u0438, \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u0438 \u0438 \u043b\u043e\u0433\u0438\u043a\u0435. \u042d\u0442\u043e \u043a\u043e\u0433\u043d\u0438\u0442\u0438\u0432\u043d\u0430\u044f \u0442\u043e\u0447\u043a\u0430 \u0440\u0430\u0432\u043d\u043e\u0432\u0435\u0441\u0438\u044f, \u0433\u0434\u0435 \u0431\u044b\u0441\u0442\u0440\u043e\u0435 \u043c\u044b\u0448\u043b\u0435\u043d\u0438\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044f \u0441 \u0437\u0440\u0435\u043b\u044b\u043c \u0441\u0443\u0436\u0434\u0435\u043d\u0438\u0435\u043c.",
